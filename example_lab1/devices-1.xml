<?xml version="1.0" encoding="utf-8"?>
<VmDevicesConfiguration xmlns="Portable.TargetPlatform.Vm.Devices">
  <DeviceType Name="SimplePic" Id="1" />
  <DeviceType Name="SimpleClock" Id="2" />
  <DeviceType Name="SimplePipe" Id="3" />

  <Device DeviceType="SimplePic" Name="pic0" Id="1">
    <IoPortMap PortType="state" Id="1" BankName="code" Mode="RAM">
      <InitialBinding StartAddress="0xD800" Length="0x0040" />
    </IoPortMap>
    <IoPortMap PortType="handlers-map" Id="2" BankName="code" Mode="RAM">
      <InitialBinding StartAddress="0xD840" Length="0x0100" />
    </IoPortMap>
    <Parameter Name="HandlersTableEntrySize" Value="8" />
  </Device>

  <Device DeviceType="SimpleClock" Name="clock0" Id="2">
    <IoPortMap PortType="state" Id="1" BankName="code" Mode="RAM">
      <InitialBinding StartAddress="0xDC00" Length="0x0048" />
    </IoPortMap>
    <Signal Id="0" Name="on-cycles" Interrupt="0" />
    <Parameter Name="CyclesSignalPeriod" Value="10000" />
  </Device>

  <Device DeviceType="SimplePipe" Name="StdIo" Id="3">
    <IoPortMap PortType="control" Id="1" BankName="code" Mode="RAM">
      <InitialBinding StartAddress="0xDD00" Length="0x0040" />
    </IoPortMap>
    <Parameter Name="PipeSpec" Value="stdio" />
    <Parameter Name="OperationMode" Value="ByteStream" />
  </Device>
</VmDevicesConfiguration>
